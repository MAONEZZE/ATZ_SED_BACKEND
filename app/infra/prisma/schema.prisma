generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["ATZ_SED"]
}

// ==================== ENUMS ====================

enum EventStatus {
  draft
  published
  cancelled
  ended

  @@schema("ATZ_SED")
}

enum FunnelStatus {
  pending
  approved
  rejected

  @@schema("ATZ_SED")
}

enum FormFieldKind {
  registration
  post_event
  nps

  @@schema("ATZ_SED")
}

enum FieldType {
  text
  textarea
  email
  phone
  select
  multiselect
  checkbox
  image
  date
  linkedin
  instagram

  @@schema("ATZ_SED")
}

enum MessageChannel {
  whatsapp
  email

  @@schema("ATZ_SED")
}

enum AutomationTrigger {
  on_registration
  on_post_event
  on_nps
  on_approval
  on_rejection
  before_event
  after_event
  after_approval
  recurring

  @@schema("ATZ_SED")
}

enum OutboxStatus {
  pending
  processing
  sent
  failed

  @@schema("ATZ_SED")
}

enum PipedriveStatus {
  pending
  sent
  failed
  skipped

  @@schema("ATZ_SED")
}

// ==================== MODELS ====================

model Profile {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  name             String
  email            String
  photoUrl         String?   @map("photo_url")
  evolutionInstance String?  @map("evolution_instance")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  events           Event[]   @relation("EventOwner")
  editedEvents     Event[]   @relation("EventLastEditor")
  collaborations   EventCollaborator[]
  templates        MessageTemplate[]
  outboxMessages   OutboxMessage[]
  messageLogs      MessageLog[]   @relation("MessageLogOwner")

  @@map("profiles")
  @@schema("ATZ_SED")
}

model Event {
  id                String          @id @default(uuid())
  ownerId           String          @map("owner_id")
  title             String
  slug              String          @unique
  description       String?
  coverUrl          String?         @map("cover_url")
  location          String?
  capacity          Int?
  dressCode         String?         @map("dress_code")
  groupLink         String?         @map("group_link")
  eventDate         DateTime?       @map("event_date")
  endDate           DateTime?       @map("end_date")
  postRegistrationMessage String?   @map("post_registration_message")
  sendToPipedrive   Boolean         @default(false) @map("send_to_pipedrive")
  recurrenceFreq     String?        @map("recurrence_freq")
  recurrenceInterval Int?           @map("recurrence_interval")
  recurrenceUntil    DateTime?      @map("recurrence_until")
  status            EventStatus     @default(draft)
  evolutionInstance String?         @map("evolution_instance")
  evolutionToken    String?         @map("evolution_token")
  lastEditedById    String?         @map("last_edited_by")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  owner             Profile         @relation("EventOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  lastEditedBy      Profile?        @relation("EventLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  collaborators     EventCollaborator[]
  formFields        FormField[]
  registrations     Registration[]
  postEventResponses PostEventResponse[]
  automationRules   AutomationRule[]
  outboxMessages    OutboxMessage[]
  messageLogs       MessageLog[]
  userSubscriptions UserSubscription[]
  messageTemplates  MessageTemplate[]

  @@index([ownerId])
  @@map("events")
  @@schema("ATZ_SED")
}

model EventCollaborator {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  profileId String   @map("profile_id")
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([eventId, profileId])
  @@index([profileId])
  @@map("event_collaborators")
  @@schema("ATZ_SED")
}

model FormField {
  id        String    @id @default(uuid())
  eventId   String    @map("event_id")
  label     String
  type      FieldType
  required  Boolean   @default(true)
  options   Json?
  order     Int       @default(0)
  isFixed   Boolean   @default(false) @map("is_fixed")
  kind      FormFieldKind @default(registration)
  createdAt DateTime  @default(now()) @map("created_at")
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, kind])
  @@map("form_fields")
  @@schema("ATZ_SED")
}

model Registration {
  id             String         @id @default(uuid())
  eventId        String         @map("event_id")
  status         FunnelStatus   @default(pending)
  answers        Json
  name           String
  email          String
  phone          String
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  outboxMessages OutboxMessage[]
  messageLogs    MessageLog[]
  postEventResponse PostEventResponse?

  @@index([eventId, status])
  @@map("registrations")
  @@schema("ATZ_SED")
}

model PostEventResponse {
  id             String       @id @default(uuid())
  eventId        String       @map("event_id")
  registrationId String       @map("registration_id")
  answers        Json
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId])
  @@index([eventId])
  @@map("post_event_responses")
  @@schema("ATZ_SED")
}

model UserSubscription {
  id                  String   @id @default(uuid())
  eventId             String   @map("event_id")
  name                String?
  email               String?
  phone               String?
  registrationAnswers Json?    @map("registration_answers")
  postEventAnswers    Json?    @map("post_event_answers")
  npsAnswers          Json?    @map("nps_answers")
  sendToPipedrive     Boolean  @default(false) @map("send_to_pipedrive")
  pipedriveStatus     PipedriveStatus? @map("pipedrive_status")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([eventId, email])
  @@index([eventId, phone])
  @@map("user_subscriptions")
  @@schema("ATZ_SED")
}

model MessageTemplate {
  id             String          @id @default(uuid())
  ownerId        String          @map("owner_id")
  name           String
  channel        MessageChannel
  subject        String?
  body           String
  layoutConfig   Json?           @map("layout_config")
  styleKey       String?         @map("style_key")
  eventId        String?         @map("event_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  owner          Profile         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  event          Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  automationRules AutomationRule[]
  outboxMessages  OutboxMessage[]

  @@index([ownerId])
  @@index([eventId])
  @@map("message_templates")
  @@schema("ATZ_SED")
}

model AutomationRule {
  id           String            @id @default(uuid())
  eventId      String            @map("event_id")
  templateId   String            @map("template_id")
  trigger      AutomationTrigger
  delayMinutes Int?              @map("delay_minutes")
  cron         String?
  timezone     String?
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now()) @map("created_at")
  event        Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template     MessageTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([eventId, trigger, active])
  @@map("automation_rules")
  @@schema("ATZ_SED")
}

model OutboxMessage {
  id              String         @id @default(uuid())
  eventId         String?        @map("event_id")
  ownerId         String?        @map("owner_id")
  registrationId  String?        @map("registration_id")
  templateId      String?        @map("template_id")
  trigger         String
  dedupKey        String         @unique @map("dedup_key")
  channel         MessageChannel
  recipient       String
  instancia       String?
  renderedBody    String         @map("rendered_body")
  renderedSubject String?        @map("rendered_subject")
  inviteConfig    Json?          @map("invite_config")
  status          OutboxStatus   @default(pending)
  attempts        Int            @default(0)
  sentParts       Int            @default(0) @map("sent_parts")
  attachments     Json?          @map("attachments")
  sentAttachments Int            @default(0) @map("sent_attachments")
  errorMessage    String?        @map("error_message")
  processedAt     DateTime?      @map("processed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  registration    Registration?  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  template        MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  event           Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner           Profile?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([instancia, status])
  @@index([status, createdAt])
  @@index([eventId])
  @@index([ownerId])
  @@map("outbox_messages")
  @@schema("ATZ_SED")
}

model MessageLog {
  id             String         @id @default(uuid())
  eventId        String?        @map("event_id")
  ownerId        String?        @map("owner_id")
  registrationId String?        @map("registration_id")
  channel        MessageChannel
  recipient      String
  body           String
  status         String
  errorMessage   String?        @map("error_message")
  sentAt         DateTime?      @map("sent_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  registration   Registration?  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  event          Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner          Profile?       @relation("MessageLogOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([registrationId])
  @@index([eventId])
  @@index([ownerId])
  @@map("message_logs")
  @@schema("ATZ_SED")
}

