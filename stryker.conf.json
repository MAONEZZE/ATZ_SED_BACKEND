{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "package.json"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "app/**/*.ts",
    "!app/**/*.module.ts",
    "!app/main.ts",
    "!app/database/prisma/**"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "tempDirName": "tests/mutation_test/.stryker-tmp",
  "htmlReporter": {
    "fileName": "tests/mutation_test/reports/mutation.html"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  }
}
